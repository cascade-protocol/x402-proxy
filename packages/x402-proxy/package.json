{
  "name": "x402-proxy",
  "version": "0.1.2",
  "description": "Generic x402 payment proxy library for Solana USDC",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown --publint",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && biome check --write",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/svm": "^2.6.0"
  },
  "peerDependencies": {
    "@solana/kit": "^6.0.0",
    "ethers": "^6.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@solana/kit": "^6.0.0",
    "@types/node": "^22.0.0",
    "publint": "^0.3.17",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.0",
    "viem": "^2.0.0"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascade-protocol/x402-proxy.git",
    "directory": "packages/x402-proxy"
  },
  "homepage": "https://github.com/cascade-protocol/x402-proxy#readme",
  "bugs": {
    "url": "https://github.com/cascade-protocol/x402-proxy/issues"
  }
}
