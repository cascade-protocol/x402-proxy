{
  "name": "x402-proxy",
  "private": true,
  "version": "0.11.0",
  "description": "curl for x402 paid APIs. Auto-pays any endpoint on Base, Solana, and Tempo.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openclaw": {
      "types": "./dist/openclaw/plugin.d.ts",
      "default": "./dist/openclaw/plugin.js"
    },
    "./package.json": "./package.json"
  },
  "openclaw": {
    "extensions": [
      "./dist/openclaw/plugin.js"
    ],
    "providers": [
      "surf"
    ],
    "compat": {
      "pluginApi": ">=2026.4.1",
      "minGatewayVersion": "2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  },
  "bin": {
    "x402-proxy": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "pnpm exec tsdown --config ../../tsdown.config.ts",
    "dev": "pnpm exec tsdown --config ../../tsdown.config.ts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm type-check && biome check --write",
    "stage:release": "node ../../scripts/stage-x402-packages.mjs",
    "verify:release": "node ../../scripts/verify-staged-x402-packages.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@getmcp/generators": "^0.10.1",
    "@modelcontextprotocol/sdk": "~1.27.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@sinclair/typebox": "^0.34.48",
    "@solana-program/token": "^0.12.0",
    "@solana/kit": "^6.5.0",
    "@stricli/core": "^1.2.6",
    "@x402/core": "^2.8.0",
    "@x402/evm": "^2.8.0",
    "@x402/fetch": "^2.8.0",
    "@x402/mcp": "^2.8.0",
    "@x402/svm": "^2.8.0",
    "ethers": "^6.16.0",
    "mppx": "^0.5.1",
    "picocolors": "^1.1.1",
    "viem": "^2.47.6",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openclaw": "^2026.4.1",
    "publint": "^0.3.18",
    "tsdown": "^0.21.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "files": [
    "dist/**",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "skills/**",
    "LICENSE"
  ],
  "keywords": [
    "x402",
    "mpp",
    "http-402",
    "mcp",
    "mcp-proxy",
    "ai-agent",
    "agentic-commerce",
    "base",
    "solana",
    "tempo",
    "usdc",
    "coinbase",
    "cli",
    "openclaw",
    "openclaw-plugin"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascade-protocol/x402-proxy.git",
    "directory": "packages/x402-proxy"
  },
  "homepage": "https://github.com/cascade-protocol/x402-proxy#readme",
  "bugs": {
    "url": "https://github.com/cascade-protocol/x402-proxy/issues"
  }
}
