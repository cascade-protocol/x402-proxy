{
  "name": "x402-proxy",
  "version": "0.4.2",
  "description": "curl for x402 paid APIs. Auto-pays any endpoint on Base and Solana.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "x402-proxy": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown --publint",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm type-check && biome check --write",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@solana/kit": "^6.0.0",
    "@stricli/core": "^1.2.6",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/mcp": "^2.6.0",
    "@x402/svm": "^2.6.0",
    "ethers": "^6.0.0",
    "picocolors": "^1.1.1",
    "viem": "^2.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "publint": "^0.3.17",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "skills/**",
    "LICENSE"
  ],
  "keywords": [
    "x402",
    "http-402",
    "mcp",
    "mcp-proxy",
    "ai-agent",
    "agentic-commerce",
    "base",
    "solana",
    "usdc",
    "coinbase",
    "cli"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascade-protocol/x402-proxy.git",
    "directory": "packages/x402-proxy"
  },
  "homepage": "https://github.com/cascade-protocol/x402-proxy#readme",
  "bugs": {
    "url": "https://github.com/cascade-protocol/x402-proxy/issues"
  }
}
