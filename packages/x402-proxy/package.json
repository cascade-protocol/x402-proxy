{
  "name": "x402-proxy",
  "version": "0.8.3",
  "description": "curl for x402 paid APIs. Auto-pays any endpoint on Base, Solana, and Tempo. Also works as an OpenClaw plugin.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openclaw": {
      "types": "./dist/openclaw/plugin.d.ts",
      "default": "./dist/openclaw/plugin.js"
    },
    "./package.json": "./package.json"
  },
  "openclaw": {
    "extensions": [
      "./dist/openclaw/plugin.js"
    ]
  },
  "bin": {
    "x402-proxy": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown --publint && cp openclaw.plugin.json dist/",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm type-check && biome check --write",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@solana/kit": "^6.0.0",
    "@sinclair/typebox": "^0.34.48",
    "@stricli/core": "^1.2.6",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/mcp": "^2.6.0",
    "mppx": "^0.4.9",
    "@x402/svm": "^2.6.0",
    "ethers": "^6.0.0",
    "picocolors": "^1.1.1",
    "viem": "^2.0.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.8"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.3.8",
    "publint": "^0.3.17",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist/**",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "skills/**",
    "LICENSE"
  ],
  "keywords": [
    "x402",
    "mpp",
    "http-402",
    "mcp",
    "mcp-proxy",
    "ai-agent",
    "agentic-commerce",
    "base",
    "solana",
    "tempo",
    "usdc",
    "coinbase",
    "cli",
    "openclaw",
    "openclaw-plugin"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascade-protocol/x402-proxy.git",
    "directory": "packages/x402-proxy"
  },
  "homepage": "https://github.com/cascade-protocol/x402-proxy#readme",
  "bugs": {
    "url": "https://github.com/cascade-protocol/x402-proxy/issues"
  }
}
